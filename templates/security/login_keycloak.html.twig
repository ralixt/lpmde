{% extends 'base.html.twig' %}

{% block title %}Connexion — La Petite Maison de l'Épouvante{% endblock %}

{% block body %}
<div class="min-h-screen flex items-center justify-center px-4 py-20">

    <div class="absolute inset-0 pointer-events-none overflow-hidden" aria-hidden="true">
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-primary/5 rounded-full blur-3xl"></div>
    </div>

    <div class="relative w-full max-w-md space-y-8">

        <div class="text-center space-y-4">
            <span class="inline-block px-3 py-1 bg-primary/20 text-primary border border-primary/30 text-[10px] font-bold uppercase tracking-widest rounded">
                Accès membres
            </span>
            <h1 class="text-4xl font-black uppercase tracking-tighter text-white leading-none">
                Entrez dans<br/><span class="text-primary italic">le sanctuaire</span>
            </h1>
            <p class="text-slate-400 text-sm">Authentification sécurisée via Keycloak</p>
        </div>

        {% for message in app.flashes('error') %}
            <div role="alert" class="flex items-start gap-3 bg-primary/10 border border-primary/30 rounded-xl p-4">
                <span class="material-symbols-outlined text-primary text-sm mt-0.5" aria-hidden="true">warning</span>
                <p class="text-sm text-slate-300">{{ message }}</p>
            </div>
        {% endfor %}

        {% for message in app.flashes('info') %}
            <output class="flex items-start gap-3 bg-white/5 border border-white/10 rounded-xl p-4">
                <span class="material-symbols-outlined text-slate-400 text-sm mt-0.5" aria-hidden="true">info</span>
                <p class="text-sm text-slate-300">{{ message }}</p>
            </output>
        {% endfor %}

        <div class="bg-surface-dark border border-white/10 rounded-2xl p-8 space-y-6">

            <div class="flex items-center gap-4 pb-6 border-b border-white/5">
                <div class="w-12 h-12 rounded-xl bg-primary/20 border border-primary/30 flex items-center justify-center" aria-hidden="true">
                    <span class="material-symbols-outlined text-primary" aria-hidden="true">lock</span>
                </div>
                <div>
                    <h2 class="font-bold text-white tracking-tight">Connexion Keycloak</h2>
                    <p class="text-xs text-slate-500 uppercase tracking-widest">OAuth 2.0 / OpenID Connect</p>
                </div>
            </div>

            <p class="text-sm text-slate-400 leading-relaxed">
                Accédez à votre compte pour participer aux échanges, gérer vos annonces et rejoindre la communauté des collectionneurs du macabre.
            </p>

            <a href="{{ path('app_login_keycloak_redirect') }}"
               class="w-full flex items-center justify-center gap-3 bg-primary hover:bg-primary/90 text-white font-bold py-4 px-6 rounded-lg transition-all uppercase text-sm tracking-widest group"
               data-tooltip="Authentification Keycloak">
                <span class="material-symbols-outlined group-hover:rotate-12 transition-transform" aria-hidden="true">key</span>
                Se connecter avec Keycloak
                <span class="material-symbols-outlined group-hover:translate-x-1 transition-transform" aria-hidden="true">arrow_forward</span>
            </a>

            <div class="flex items-center gap-3" aria-hidden="true">
                <div class="flex-1 h-px bg-white/5"></div>
                <span class="text-[10px] text-slate-600 uppercase tracking-widest">sécurisé</span>
                <div class="flex-1 h-px bg-white/5"></div>
            </div>

            <div class="flex items-center justify-center gap-6 text-[10px] text-slate-600 uppercase tracking-widest" aria-hidden="true">
                <span class="flex items-center gap-1.5">
                    <span class="material-symbols-outlined text-xs" aria-hidden="true">shield</span>
                    Chiffré
                </span>
                <span class="flex items-center gap-1.5">
                    <span class="material-symbols-outlined text-xs" aria-hidden="true">verified_user</span>
                    OIDC
                </span>
                <span class="flex items-center gap-1.5">
                    <span class="material-symbols-outlined text-xs" aria-hidden="true">token</span>
                    JWT
                </span>
            </div>
        </div>

        <div class="text-center">
            <a href="{{ path('homepage') }}" class="inline-flex items-center gap-2 text-xs text-slate-500 hover:text-primary transition-colors uppercase tracking-widest" data-tooltip="Retour à l'accueil">
                <span class="material-symbols-outlined text-sm" aria-hidden="true">arrow_back</span>
                Retour à l'accueil
            </a>
        </div>

    </div>
</div>
{% endblock %}

{% extends 'base.html.twig' %}

{% block title %}Mon Profil — La Petite Maison de l'Épouvante{% endblock %}

{% block body %}
<div class="max-w-[1200px] mx-auto px-4 lg:px-10 py-20 space-y-12">

    <!-- Page header -->
    <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-6">
        <div class="space-y-3">
            <span class="inline-block px-3 py-1 bg-primary/20 text-primary border border-primary/30 text-[10px] font-bold uppercase tracking-widest rounded">
                Mon compte
            </span>
            <h1 class="text-5xl font-black uppercase tracking-tighter text-white leading-none">
                {{ user_name }}
            </h1>
            <p class="text-slate-500 text-sm uppercase tracking-widest">{{ user_email }}</p>
        </div>

        <a href="{{ path('app_logout') }}"
           class="inline-flex items-center gap-2 bg-primary/20 hover:bg-primary border border-primary/40 text-white font-bold py-3 px-6 rounded-lg transition-all uppercase text-xs tracking-widest group">
            <span class="material-symbols-outlined text-sm">logout</span>
            Déconnexion
        </a>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

        <!-- Left column: Profile info -->
        <div class="lg:col-span-2 space-y-6">

            <!-- Identity card -->
            <div class="bg-surface-dark border border-white/10 rounded-2xl overflow-hidden">
                <div class="flex items-center gap-4 p-6 border-b border-white/5">
                    <span class="material-symbols-outlined text-primary">person</span>
                    <h2 class="font-bold uppercase tracking-widest text-xs text-white">Informations du profil</h2>
                </div>
                <div class="p-6 space-y-4">
                    <div class="bg-white/5 border border-white/5 rounded-xl p-4">
                        <p class="text-[10px] font-bold uppercase tracking-widest text-slate-500 mb-1">Nom complet</p>
                        <p class="text-white font-semibold">{{ user_name }}</p>
                    </div>
                    <div class="bg-white/5 border border-white/5 rounded-xl p-4">
                        <p class="text-[10px] font-bold uppercase tracking-widest text-slate-500 mb-1">Adresse e-mail</p>
                        <p class="text-white font-semibold">{{ user_email }}</p>
                    </div>
                    <div class="flex items-center gap-3 bg-primary/10 border border-primary/20 rounded-xl p-4">
                        <span class="material-symbols-outlined text-primary">verified</span>
                        <div>
                            <p class="font-bold text-sm text-white">Authentifié via Keycloak</p>
                            <p class="text-[10px] text-slate-500 uppercase tracking-widest">OAuth 2.0 / OpenID Connect</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Quick actions -->
            <div class="bg-surface-dark border border-white/10 rounded-2xl overflow-hidden">
                <div class="flex items-center gap-4 p-6 border-b border-white/5">
                    <span class="material-symbols-outlined text-primary">bolt</span>
                    <h2 class="font-bold uppercase tracking-widest text-xs text-white">Actions rapides</h2>
                </div>
                <div class="p-6 grid grid-cols-1 sm:grid-cols-2 gap-4">
                    <a href="{{ path('troc_index') }}"
                       class="flex items-center gap-3 bg-white/5 border border-white/10 hover:border-primary/50 rounded-xl p-4 transition-colors group">
                        <span class="material-symbols-outlined text-slate-500 group-hover:text-primary transition-colors">swap_horiz</span>
                        <div>
                            <p class="font-bold text-sm text-white">Espace Troc</p>
                            <p class="text-[10px] text-slate-500 uppercase tracking-widest">Toutes les annonces</p>
                        </div>
                    </a>
                    <a href="{{ path('troc_mes_annonces') }}"
                       class="flex items-center gap-3 bg-white/5 border border-white/10 hover:border-primary/50 rounded-xl p-4 transition-colors group">
                        <span class="material-symbols-outlined text-slate-500 group-hover:text-primary transition-colors">list_alt</span>
                        <div>
                            <p class="font-bold text-sm text-white">Mes annonces</p>
                            <p class="text-[10px] text-slate-500 uppercase tracking-widest">Gérer mes offres</p>
                        </div>
                    </a>
                    <a href="{{ path('troc_new') }}"
                       class="flex items-center gap-3 bg-white/5 border border-white/10 hover:border-primary/50 rounded-xl p-4 transition-colors group">
                        <span class="material-symbols-outlined text-slate-500 group-hover:text-primary transition-colors">add_circle</span>
                        <div>
                            <p class="font-bold text-sm text-white">Nouvelle annonce</p>
                            <p class="text-[10px] text-slate-500 uppercase tracking-widest">Publier un échange</p>
                        </div>
                    </a>
                    <a href="{{ path('homepage') }}"
                       class="flex items-center gap-3 bg-white/5 border border-white/10 hover:border-primary/50 rounded-xl p-4 transition-colors group">
                        <span class="material-symbols-outlined text-slate-500 group-hover:text-primary transition-colors">home</span>
                        <div>
                            <p class="font-bold text-sm text-white">Accueil</p>
                            <p class="text-[10px] text-slate-500 uppercase tracking-widest">Retour au sanctuaire</p>
                        </div>
                    </a>
                </div>
            </div>

        </div>

        <!-- Right column: Stats & tech -->
        <div class="space-y-6">

            <!-- Avatar card -->
            <div class="bg-surface-dark border border-white/10 rounded-2xl p-6 flex flex-col items-center gap-4 text-center">
                <div class="w-20 h-20 rounded-full bg-primary/20 border-2 border-primary/30 flex items-center justify-center">
                    <span class="material-symbols-outlined text-primary" style="font-size: 2.5rem;">account_circle</span>
                </div>
                <div>
                    <p class="font-black text-lg uppercase tracking-tighter text-white">{{ user_name }}</p>
                    <p class="text-[10px] text-primary uppercase tracking-widest font-bold">Membre actif</p>
                </div>
            </div>

            <!-- Tech stack -->
            <div class="bg-surface-dark border border-white/10 rounded-2xl overflow-hidden">
                <div class="p-4 border-b border-white/5">
                    <p class="text-[10px] font-bold uppercase tracking-widest text-slate-500">Stack technique</p>
                </div>
                <div class="divide-y divide-white/5">
                    <div class="flex items-center gap-3 p-4">
                        <span class="material-symbols-outlined text-primary text-sm">key</span>
                        <div>
                            <p class="text-xs font-bold text-white">Keycloak</p>
                            <p class="text-[10px] text-slate-600 uppercase">Authentification</p>
                        </div>
                        <span class="ml-auto text-[10px] text-primary font-bold uppercase tracking-widest">OAuth 2.0</span>
                    </div>
                    <div class="flex items-center gap-3 p-4">
                        <span class="material-symbols-outlined text-primary text-sm">token</span>
                        <div>
                            <p class="text-xs font-bold text-white">JWT Token</p>
                            <p class="text-[10px] text-slate-600 uppercase">Session</p>
                        </div>
                        <span class="ml-auto text-[10px] text-primary font-bold uppercase tracking-widest">OIDC</span>
                    </div>
                    <div class="flex items-center gap-3 p-4">
                        <span class="material-symbols-outlined text-primary text-sm">queue</span>
                        <div>
                            <p class="text-xs font-bold text-white">RabbitMQ</p>
                            <p class="text-[10px] text-slate-600 uppercase">Messaging</p>
                        </div>
                        <span class="ml-auto text-[10px] text-primary font-bold uppercase tracking-widest">AMQP</span>
                    </div>
                </div>
            </div>

            <!-- Info notice -->
            <div class="flex items-start gap-3 bg-white/5 border border-white/10 rounded-xl p-4">
                <span class="material-symbols-outlined text-slate-500 text-sm mt-0.5">info</span>
                <p class="text-xs text-slate-400 leading-relaxed">
                    Votre connexion a été enregistrée de manière asynchrone via RabbitMQ.
                </p>
            </div>

        </div>
    </div>

</div>
{% endblock %}

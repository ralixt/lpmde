{% extends 'base.html.twig' %}

{% block title %}Mon Profil{% endblock %}

{% block body %}
<div class="min-h-screen bg-gradient-to-br from-red-900 to-red-700 py-12 px-4">
    <div class="max-w-4xl mx-auto">
        <!-- Header -->
        <div class="bg-white rounded-t-2xl shadow-xl p-8 border-b-4 border-purple-500">
            <div class="flex items-center justify-between">
                <div class="flex items-center space-x-4">
                    <div class="w-20 h-20 bg-gradient-to-br from-red-500 to-red-600 rounded-full flex items-center justify-center text-4xl">
                        👤
                    </div>
                    <div>
                        <h1 class="text-3xl font-bold text-gray-900">{{ user_name }}</h1>
                        <p class="text-gray-600 mt-1">{{ user_email }}</p>
                    </div>
                </div>
                <a href="{{ path('app_logout') }}" 
                   class="px-6 py-3 bg-red-500 hover:bg-red-600 text-white font-semibold rounded-lg transition-colors">
                    Déconnexion
                </a>
            </div>
        </div>

        <!-- Content -->
        <div class="bg-white rounded-b-2xl shadow-xl p-8">
            <div class="grid md:grid-cols-2 gap-6">
                <!-- Profile Info -->
                <div class="space-y-4">
                    <h2 class="text-xl font-bold text-gray-900 mb-4 flex items-center">
                        <span class="text-2xl mr-2"></span>
                        Informations du profil
                    </h2>
                    
                    <div class="bg-gray-50 rounded-lg p-4">
                        <div class="text-sm font-semibold text-gray-600">Nom complet</div>
                        <p class="text-lg text-gray-900 mt-1">{{ user_name }}</p>
                    </div>

                    <div class="bg-gray-50 rounded-lg p-4">
                        <div class="text-sm font-semibold text-gray-600">Email</div>
                        <p class="text-lg text-gray-900 mt-1">{{ user_email }}</p>
                    </div>

                    <div class="bg-gradient-to-r from-green-50 to-emerald-50 border border-green-200 rounded-lg p-4">
                        <div class="flex items-center">
                            <span class="text-2xl mr-3"></span>
                            <div>
                                <p class="font-semibold text-green-800">Authentifié via Keycloak</p>
                                <p class="text-sm text-green-600">OAuth 2.0 / OpenID Connect</p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Actions -->
                <div class="space-y-4">
                    <h2 class="text-xl font-bold text-gray-900 mb-4 flex items-center">
                        <span class="text-2xl mr-2"></span>
                        Actions rapides
                    </h2>

                    <a href="{{ path('homepage') }}" 
                       class="block w-full px-6 py-4 bg-gradient-to-r from-purple-600 to-indigo-600 text-white font-semibold rounded-lg hover:from-purple-700 hover:to-indigo-700 transition-all text-center">
                        Retour à l'accueil
                    </a>

                    <a href="{{ path('app_test_rabbit') }}" 
                       class="block w-full px-6 py-4 bg-gradient-to-r from-orange-500 to-red-500 text-white font-semibold rounded-lg hover:from-orange-600 hover:to-red-600 transition-all text-center">
                        Tester RabbitMQ (50 messages)
                    </a>

                    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 mt-4">
                        <p class="text-sm text-blue-800">
                            <strong>Info :</strong> Votre connexion a été enregistrée via RabbitMQ de manière asynchrone.
                        </p>
                    </div>
                </div>
            </div>

            <!-- Stats Cards -->
            <div class="grid grid-cols-3 gap-4 mt-8 pt-8 border-t border-gray-200">
                <div class="bg-gradient-to-br from-purple-500 to-purple-600 rounded-xl p-6 text-white">
                    <div class="text-3xl mb-2"></div>
                    <p class="text-2xl font-bold">OAuth 2.0</p>
                    <p class="text-sm opacity-90">Authentification</p>
                </div>
                <div class="bg-gradient-to-br from-blue-500 to-blue-600 rounded-xl p-6 text-white">
                    <div class="text-3xl mb-2"></div>
                    <p class="text-2xl font-bold">RabbitMQ</p>
                    <p class="text-sm opacity-90">Messaging</p>
                </div>
                <div class="bg-gradient-to-br from-green-500 to-green-600 rounded-xl p-6 text-white">
                    <div class="text-3xl mb-2"></div>
                    <p class="text-2xl font-bold">Connecté</p>
                    <p class="text-sm opacity-90">Keycloak</p>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

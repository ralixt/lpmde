{% extends 'base.html.twig' %}

{% block title %}Connexion — La Petite Maison de l'Épouvante{% endblock %}

{% block body %}
<div class="min-h-screen flex items-center justify-center px-4 py-20">

    <div class="absolute inset-0 pointer-events-none overflow-hidden" aria-hidden="true">
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-primary/5 rounded-full blur-3xl"></div>
    </div>

    <div class="relative w-full max-w-md space-y-8">

        <div class="text-center space-y-3">
            <span class="inline-block px-3 py-1 bg-primary/20 text-primary border border-primary/30 text-[10px] font-bold uppercase tracking-widest rounded">
                Connexion
            </span>
            <h1 class="text-4xl font-black uppercase tracking-tighter text-white leading-none">
                Accès<br/><span class="text-primary italic">membres</span>
            </h1>
        </div>

        <div class="bg-surface-dark border border-white/10 rounded-2xl p-8 space-y-6">

            <form method="POST" action="{{ path('app_do_login') }}" class="space-y-5" novalidate>

                <div class="space-y-2">
                    <label for="username" class="block text-[10px] font-bold uppercase tracking-widest text-slate-400">
                        Nom d'utilisateur
                    </label>
                    <div class="relative">
                        <span class="absolute left-4 top-1/2 -translate-y-1/2 material-symbols-outlined text-slate-600 text-sm" aria-hidden="true">person</span>
                        <input
                            type="text"
                            id="username"
                            name="username"
                            placeholder="Votre identifiant"
                            required
                            autocomplete="username"
                            class="w-full bg-white/5 border border-white/10 focus:border-primary/50 focus:ring-1 focus:ring-primary/30 rounded-xl py-3 pl-11 pr-4 text-sm text-white placeholder-slate-600 outline-none transition-all"
                        >
                    </div>
                </div>

                <button
                    type="submit"
                    class="w-full flex items-center justify-center gap-3 bg-primary hover:bg-primary/90 text-white font-bold py-4 px-6 rounded-lg transition-all uppercase text-sm tracking-widest group">
                    <span class="material-symbols-outlined text-sm" aria-hidden="true">login</span>
                    Se connecter
                    <span class="material-symbols-outlined group-hover:translate-x-1 transition-transform text-sm" aria-hidden="true">arrow_forward</span>
                </button>

            </form>

            <div class="flex items-center gap-3" aria-hidden="true">
                <div class="flex-1 h-px bg-white/5"></div>
                <span class="text-[10px] text-slate-600 uppercase tracking-widest">ou</span>
                <div class="flex-1 h-px bg-white/5"></div>
            </div>

            <a href="{{ path('app_login_keycloak_redirect') }}"
               class="w-full flex items-center justify-center gap-3 bg-white/5 hover:bg-white/10 border border-white/10 hover:border-primary/40 text-white font-bold py-3 px-6 rounded-lg transition-all uppercase text-xs tracking-widest">
                <span class="material-symbols-outlined text-sm text-primary" aria-hidden="true">key</span>
                Connexion via Keycloak
            </a>
        </div>

        <div class="text-center">
            <a href="{{ path('homepage') }}" class="inline-flex items-center gap-2 text-xs text-slate-500 hover:text-primary transition-colors uppercase tracking-widest">
                <span class="material-symbols-outlined text-sm" aria-hidden="true">arrow_back</span>
                Retour à l'accueil
            </a>
        </div>

    </div>
</div>
{% endblock %}

{% extends 'base.html.twig' %}

{% block title %}Espace Troc{% endblock %}

{% block body %}
<div class="min-h-screen bg-background-dark py-8 px-4">
    <div class="max-w-7xl mx-auto">

        {# En-tête #}
        <div class="mb-8">
            <h1 class="text-4xl font-bold text-white font-display mb-2">
                <span class="text-primary">🩸</span> Espace Troc
            </h1>
            <p class="text-slate-400">Échangez et donnez vos trésors de l'horreur entre passionnés</p>
        </div>

        {# Flash messages #}
        {% for type, messages in app.flashes %}
            {% for message in messages %}
                <div class="mb-4 p-4 rounded border
                    {% if type == 'success' %}bg-green-900/50 border-green-700 text-green-300
                    {% elseif type == 'error' %}bg-red-900/50 border-primary text-red-300
                    {% else %}bg-slate-800 border-slate-600 text-slate-300{% endif %}">
                    {{ message }}
                </div>
            {% endfor %}
        {% endfor %}

        {# Filtres par catégorie #}
        <div class="flex flex-wrap gap-2 mb-8">
            <a href="{{ path('troc_index') }}"
               class="px-4 py-2 rounded-full text-sm font-medium transition-colors
                      {% if not currentCategory %}bg-primary text-white{% else %}bg-surface-dark text-slate-300 border border-slate-700 hover:border-primary{% endif %}">
                Tout
            </a>
            {% for cat in categories %}
                <a href="{{ path('troc_index', {category: cat}) }}"
                   class="px-4 py-2 rounded-full text-sm font-medium transition-colors
                          {% if currentCategory == cat %}bg-primary text-white{% else %}bg-surface-dark text-slate-300 border border-slate-700 hover:border-primary{% endif %}">
                    {{ cat }}
                </a>
            {% endfor %}
        </div>

        {# Bouton publier #}
        <div class="flex justify-between items-center mb-6">
            <p class="text-slate-400 text-sm">{{ annonces|length }} annonce(s)</p>
            {% if app.session.get('is_authenticated') %}
                <a href="{{ path('troc_new') }}"
                   class="bg-primary hover:bg-red-700 text-white px-5 py-2 rounded font-medium transition-colors">
                    + Publier une annonce
                </a>
            {% else %}
                <a href="{{ path('app_login_keycloak') }}"
                   class="bg-surface-dark border border-slate-600 hover:border-primary text-slate-300 px-5 py-2 rounded font-medium transition-colors">
                    Connectez-vous pour publier
                </a>
            {% endif %}
        </div>

        {# Grille d'annonces #}
        {% if annonces is empty %}
            <div class="text-center py-20 text-slate-500">
                <p class="text-6xl mb-4">👻</p>
                <p class="text-xl">Aucune annonce pour le moment.</p>
                <p class="text-sm mt-2">Soyez le premier à publier dans l'Espace Troc !</p>
            </div>
        {% else %}
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
                {% for annonce in annonces %}
                    <a href="{{ path('troc_show', {id: annonce.id}) }}"
                       class="block bg-surface-dark rounded-xl overflow-hidden border border-slate-800 hover:border-primary transition-all hover:-translate-y-1 group">
                        {# Image #}
                        <div class="h-40 bg-slate-900 flex items-center justify-center overflow-hidden">
                            {% if annonce.imageUrl %}
                                <img src="{{ annonce.imageUrl }}" alt="{{ annonce.title }}" class="w-full h-full object-cover">
                            {% else %}
                                <span class="text-5xl">
                                    {% if annonce.category == 'Figurines' %}🗿
                                    {% elseif annonce.category == 'Films' %}🎬
                                    {% elseif annonce.category == 'Jeux' %}🎲
                                    {% elseif annonce.category == 'Fanzines' %}📰
                                    {% else %}📚{% endif %}
                                </span>
                            {% endif %}
                        </div>

                        <div class="p-4">
                            {# Badges #}
                            <div class="flex gap-2 mb-2">
                                <span class="px-2 py-0.5 rounded text-xs font-medium
                                    {% if annonce.type == 'exchange' %}bg-blue-900/50 text-blue-300{% else %}bg-green-900/50 text-green-300{% endif %}">
                                    {% if annonce.type == 'exchange' %}⇄ Échange{% else %}🎁 Don{% endif %}
                                </span>
                                <span class="px-2 py-0.5 rounded text-xs bg-slate-700 text-slate-300">
                                    {{ annonce.category }}
                                </span>
                            </div>

                            <h3 class="text-white font-semibold text-sm group-hover:text-primary transition-colors line-clamp-2">
                                {{ annonce.title }}
                            </h3>

                            <p class="text-slate-500 text-xs mt-1">État : {{ annonce.condition }}</p>
                            <p class="text-slate-600 text-xs mt-2">
                                Par {{ annonce.owner.getFullName() }} · {{ annonce.createdAt|date('d/m/Y') }}
                            </p>
                        </div>
                    </a>
                {% endfor %}
            </div>
        {% endif %}

    </div>
</div>
{% endblock %}

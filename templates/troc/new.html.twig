{% extends 'base.html.twig' %}

{% block title %}Publier une annonce{% endblock %}

{% block body %}
<div class="min-h-screen bg-background-dark py-12 px-4">
    <div class="max-w-2xl mx-auto">

        <a href="{{ path('troc_index') }}" class="flex items-center gap-2 text-slate-400 hover:text-white text-xs font-bold uppercase tracking-widest mb-8 transition-colors w-fit">
            <span class="material-symbols-outlined text-base">arrow_back</span>
            Retour aux annonces
        </a>

        <div class="bg-surface-dark rounded-2xl border border-white/5 p-8">
            <div class="mb-8">
                <span class="inline-block px-3 py-1 bg-primary/20 text-primary border border-primary/30 text-[10px] font-bold uppercase tracking-widest rounded mb-4">Troc Zone</span>
                <h1 class="text-4xl font-black uppercase tracking-tighter text-white leading-none">Publier une annonce</h1>
                <p class="text-slate-500 text-sm mt-2 uppercase tracking-widest">Partagez un trésor de l'horreur</p>
            </div>

            {{ form_start(form, {attr: {class: 'space-y-6'}}) }}

                {% for field in form %}
                    <div>
                        {{ form_label(field, null, {label_attr: {class: 'block text-slate-300 text-xs font-bold uppercase tracking-widest mb-2'}}) }}
                        {{ form_widget(field) }}
                        {{ form_errors(field) }}
                    </div>
                {% endfor %}

                <div class="flex gap-4 pt-4">
                    <button type="submit"
                            class="flex-1 flex items-center justify-center gap-2 bg-primary hover:bg-red-700 text-white py-3 rounded font-bold transition-colors text-xs uppercase tracking-widest">
                        <span class="material-symbols-outlined text-base">publish</span>
                        Publier l'annonce
                    </button>
                    <a href="{{ path('troc_index') }}"
                       class="flex items-center gap-2 px-6 py-3 bg-white/5 hover:bg-white/10 border border-white/10 text-white rounded font-medium transition-colors text-xs uppercase tracking-widest">
                        <span class="material-symbols-outlined text-base">close</span>
                        Annuler
                    </a>
                </div>

            {{ form_end(form) }}
        </div>

    </div>
</div>
{% endblock %}
